# ==================== Backend (apps/api) ====================
# Clave de la API de Anthropic (Claude). SOLO se usa en el backend.
# En producción (Vercel) ponla en Project Settings -> Environment Variables.
ANTHROPIC_API_KEY=

# ==================== Frontend (apps/mobile) ====================
# URL del backend que usa el cliente Expo.
# Dev local: http://localhost:3000
# Web prod: la URL del deploy de `apps/api` en Vercel (p.ej. https://app-entrevistas-cv-api.vercel.app).
# Nativo (EAS): también va aquí; se inyecta en build time.
# Prefijo EXPO_PUBLIC_ => expuesta al cliente (no meter secretos aquí).
EXPO_PUBLIC_API_URL=http://localhost:3000
