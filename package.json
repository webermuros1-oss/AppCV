{
  "name": "app-entrevistas-cv",
  "version": "0.1.0",
  "private": true,
  "description": "App multiplataforma para practicar entrevistas de trabajo por voz (iOS/Android/Web)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "pnpm --filter mobile start",
    "api:dev": "pnpm --filter api dev",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "eslint": "^8.57.1",
    "@typescript-eslint/parser": "^8.8.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0"
  }
}
